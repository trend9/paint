rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
             request.auth.token.email == "mattan029@gmail.com" &&
             request.auth.token.email_verified == true;
    }

    // Coloring pages collection security setup
    match /coloringPages/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
